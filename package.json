{
  "name": "islandwind-imyourfans",
  "version": "1.0.0",
  "description": "An Electron app featuring image fetching, Weibo hot topics, and translation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --debug",
    "build": "electron-builder --win --publish never",
    "publish": "electron-builder --win --publish always"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "sharp": "^0.32.6"
  },
  "build": {
    "appId": "com.islandwind.imyourfans",
    "productName": "岛风酱我是你的粉丝啊",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable"
        }
      ],
      "icon": "assets/asuka.jpg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/asuka.jpg"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/asuka.jpg"
    }
  }
}
