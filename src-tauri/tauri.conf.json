{
  "productName": "AnimeImageDownloader",
  "version": "0.1.0",
  "identifier": "com.islandwind.imyourfans",
  "build": {
    "beforeDevCommand": "cd frontend && trunk serve --port 1421",
    "beforeBuildCommand": "cd frontend && trunk build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Anime Image Downloader",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
      "shell": {
          "open": true
      }
  }
}
