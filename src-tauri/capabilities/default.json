{
  "identifier": "default",
  "description": "Default permissions for the app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        "https://cnmiw.com/*",
        "https://setu.iw233.top/*",
        "https://*.iw233.top/*",
        "https://weibo.com/*",
        "https://*.weibo.com/*",
        "https://*.sinaimg.cn/*"
      ]
    },
    "dialog:default",
    "fs:default",
    "fs:allow-picture-write",
    "fs:allow-download-write",
    "fs:allow-desktop-write",
    "fs:allow-write-file",
    "core:webview:allow-internal-toggle-devtools"
  ]
}
